# Neon PostgreSQL connection string
# Example: postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/cashcrush?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# JWT secret — use a long random string in production (openssl rand -base64 64)
JWT_SECRET="change-me-to-a-long-random-secret-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS) — comma-separated for multiple origins
CLIENT_URL="http://localhost:5173"

# Optional: Google OAuth (future)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
